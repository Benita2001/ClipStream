# RPC endpoint for Arc Testnet. Use a Canteen-hosted RPC URL (from `arc-canteen`/ARC CLI),
# or Circle's public testnet endpoint as a fallback.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Private key of the wallet that will deploy the contracts and act as campaign organizer
# in the manual test-flow script. Must be funded with Arc testnet gas/USDC — USDC is
# Arc's native gas currency (not an ERC20 token), so this one balance covers both.
# (faucet: https://faucet.circle.com/). Never commit a real key.
DEPLOYER_PRIVATE_KEY=0xyour_deployer_private_key

# Private key for a second wallet used as the `authorizedAgent` in the manual test-flow
# script (simulates the Settlement Agent calling `release`). Can be any funded-with-gas
# testnet wallet distinct from the deployer/organizer.
AGENT_PRIVATE_KEY=0xyour_agent_private_key

# Address to use as the clipper recipient in the manual test-flow script.
CLIPPER_ADDRESS=0xclipper_wallet_address

# Optional: path to write deployed contract addresses to (defaults to deployments.json
# in the project root).
DEPLOYMENTS_OUT=./deployments.json

# --- X (Twitter) API v2 ---
# Port the local Express server (OAuth linking + clip submission) listens on.
PORT=3000

# OAuth 2.0 (Authorization Code + PKCE, confidential client) credentials for the
# one-time "Sign in with X" account-linking flow. From your X Developer App's
# "Keys and tokens" > "OAuth 2.0 Client ID and Secret" page.
X_OAUTH_CLIENT_ID=your_x_oauth_client_id
X_OAUTH_CLIENT_SECRET=your_x_oauth_client_secret
# Must exactly match a Callback URI configured in the X app's User authentication
# settings (e.g. http://localhost:3000/auth/x/callback for local dev).
X_OAUTH_REDIRECT_URI=http://localhost:3000/auth/x/callback

# App-only Bearer token (from the same X Developer App's "Keys and tokens" page)
# used for reading public tweet data — impression counts and tweet author —
# no clipper auth involved. X API is pay-per-use with no free tier as of 2026;
# this requires a funded developer account.
X_OAUTH_BEARER_TOKEN=your_x_app_only_bearer_token

# How often the View Poller reads each active clip's impression_count, in
# seconds. Keep this sane against X's 15-minute rolling rate-limit window —
# don't set this aggressively low for more than a handful of test clips.
VIEW_POLL_INTERVAL_SECONDS=60

# How often the Settlement Worker checks pending_settlements for 'pending'
# rows and processes them (escrow.release() + payoutRegistry.recordPayout()),
# in seconds.
SETTLEMENT_INTERVAL_SECONDS=60

# How often the Pacing Agent re-evaluates per-clip effective_cpm_rate across
# each active campaign, in seconds. Coarser than the poll/settlement
# intervals by default — rate reallocation doesn't need to react as fast as
# reading views or paying out.
PACING_INTERVAL_SECONDS=120

# Anthropic API key for the Pacing Agent's LLM-augmented reasoning layer
# (pacing/llmAdvisor.ts). Claude only ever proposes a bounded adjustment on
# top of the deterministic pacing decision — see that file's top-of-file
# comment. If unset, or if the API call fails/returns something invalid, the
# Pacing Agent falls back to the deterministic-only result and logs why.
ANTHROPIC_API_KEY=your_anthropic_api_key
